.btn-exportar {
  border: none;
  background-color: #007bff;
  color: white;
  padding:80px 50px;
  font-size: 35px;
  font-weight: bold;
  border-radius: 5px;
  
  
  cursor: pointer;
  
  transition: background-color 0.3s ease;
}

